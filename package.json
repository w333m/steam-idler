{
    "name": "steam-idler",
    "version": "1.11",
    "description": "Headless cross-platform Steam game idler with multi account support!",
    "main": "idler.js",
    "bin": "idler.js",
    "dependencies": {
        "@seald-io/nedb": "^4.1.2",
        "output-logger": "^2.3.8",
        "qrcode": "^1.5.4",
        "steam-session": "^1.9.4",
        "steam-totp": "^2.1.2",
        "steam-user": "^5.3.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@yao-pkg/pkg": "^6.14.1",
        "eslint": "^9.39.2",
        "eslint-plugin-jsdoc": "^62.0.0"
    },
    "scripts": {
        "start": "node idler.js",
        "build": "pkg . --out-path dist"
    },
    "pkg": {
        "targets": ["node22-win-x64"],
        "assets": [
            "node_modules/@doctormckay/steam-crypto/**/*.pem",
            "node_modules/steam-user/protobufs/**/*.proto",
            "node_modules/steam-appticket/protobufs/**/*.proto",
            "node_modules/protobufjs/google/**/*.proto",
            "node_modules/lzma/src/**/*.js",
            "node_modules/@seald-io/nedb/**/*",
            "node_modules/qrcode/**/*"
        ],
        "outputPath": "dist"
    },
    "author": "3urobeat",
    "license": "GPL-3.0",
    "homepage": "https://github.com/3urobeat",
    "repository": "https://github.com/3urobeat/steam-idler"
}
